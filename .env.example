# API environment variables
# Copy to .env.local and adjust for your backend.

# Required — FastAPI backend base URL (no trailing slash)
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional — defaults match fastapi-dope-2026-template
EXPO_PUBLIC_API_PREFIX=/api/v1

# Auth path overrides (usually not needed)
# EXPO_PUBLIC_AUTH_REGISTER_PATH=/auth/register
# EXPO_PUBLIC_AUTH_LOGIN_PATH=/auth/login
# EXPO_PUBLIC_AUTH_SEND_OTP_PATH=/auth/send-otp
# EXPO_PUBLIC_AUTH_VERIFY_OTP_PATH=/auth/verify-otp
# EXPO_PUBLIC_AUTH_ME_PATH=/auth/me
# EXPO_PUBLIC_AUTH_LOGOUT_PATH=/auth/logout
# EXPO_PUBLIC_AUTH_FORGOT_PASSWORD_PATH=/auth/forgot-password
# EXPO_PUBLIC_AUTH_TOKEN_PREFIX=Bearer

# Dev only — allow http:// to non-localhost hosts (use sparingly)
# EXPO_PUBLIC_ALLOW_INSECURE_HTTP=true
